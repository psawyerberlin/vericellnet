# VeriCell configuration. Copy to `.env` and fill in — never commit the real file.
# Full reference: TECHNICAL.md §11 "Network flag"; ClaudeCodeInstruction.md Phase 10.

# --- Network (single source of truth: packages/core/src/network.ts) -------
# devnet | testnet | mainnet — default testnet. Mainnet is opt-in only.
VERICELL_NETWORK=testnet
# Web build only (baked in at build time, mirrors VERICELL_NETWORK):
# VITE_VERICELL_NETWORK=testnet
# VITE_API_URL=http://localhost:3000

# Required in addition to VERICELL_NETWORK=mainnet before custodial mode
# (or the API at all, per TECHNICAL.md §9) will start on mainnet.
MAINNET_CONFIRM=

# --- RPC ---------------------------------------------------------------
# Overrides the RPC endpoint for ANY network (self-hosted node, private
# gateway, ...). Unset = CCC's public testnet/mainnet endpoints.
VERICELL_RPC_URL=
# Devnet only, defaults to offckb's local proxy (http://127.0.0.1:28114).
VERICELL_DEVNET_RPC_URL=
# Devnet only: JSON produced by `offckb system-scripts --export-style ccc`
# — devnet's system scripts (Secp256k1Blake160, TypeId, ...) live at
# different cell-dep out points per devnet instance.
VERICELL_DEVNET_SCRIPTS_FILE=

# --- Database (network-scoped: vericell.<network>.sqlite) --------------
# Full path override — otherwise defaults to `${DB_DIR:-data}/vericell.<network>.sqlite`.
DB_PATH=
DB_DIR=

# --- API server ----------------------------------------------------------
PORT=3000
LOG_LEVEL=info

# --- Indexer worker --------------------------------------------------------
POLL_INTERVAL_MS=3000
# First block to index when sync_state is empty — set to VeriCell's actual
# first deployment height on testnet/mainnet to skip walking from genesis.
INDEXER_START_BLOCK=0

# --- Authenticated write API (TECHNICAL.md §7.2) --------------------------
# Bearer token guarding POST /api/v1/keys (key minting). Required for that
# route to work at all — unset means it always 500s rather than accepting
# any caller.
ADMIN_TOKEN=

# Custodial anchoring (POST /proofs, POST /proofs/{unid}/versions,
# DELETE /proofs/{unid}) — off by default; see TECHNICAL.md §7.2-B for the
# ownership trade-off. 1|true to enable.
CUSTODIAL_ENABLED=
# Service wallet's CKB private key, required when CUSTODIAL_ENABLED is set.
# Never commit this. On mainnet, custodial mode additionally refuses to
# start unless MAINNET_CONFIRM=1 is also set.
SERVICE_PRIVATE_KEY=
