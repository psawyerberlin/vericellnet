    "/testnet/proofs/prepare": {
      "post": {
        "summary": "Build an unsigned anchor or withdraw transaction for the caller to sign locally",
        "tags": [
          "proofs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "withdraw_tx_hash": {
                        "type": "string",
                        "pattern": "^0x[0-9a-fA-F]{64}$"
                      }
                    },
                    "required": [
                      "withdraw_tx_hash"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "manifest": {
                        "type": "object",
                        "properties": {
                          "title": {
                            "type": "string",
                            "minLength": 1
                          },
                          "created": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "source": {
                            "type": "string",
                            "format": "uri"
                          },
                          "files": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "p": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "h": {
                                  "type": "string",
                                  "pattern": "^[0-9a-f]{64}$"
                                }
                              },
                              "required": [
                                "p",
                                "h"
                              ],
                              "additionalProperties": false
                            },
                            "minItems": 1
                          },
                          "compact": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "title",
                          "files"
                        ],
                        "additionalProperties": false
                      },
                      "payer": {
                        "type": "object",
                        "properties": {
                          "lock": {
                            "type": "object",
                            "properties": {
                              "codeHash": {
                                "type": "string",
                                "pattern": "^0x[0-9a-fA-F]{64}$"
                              },
                              "hashType": {
                                "type": "string",
                                "enum": [
                                  "type",
                                  "data",
                                  "data1",
                                  "data2"
                                ]
                              },
                              "args": {
                                "type": "string",
                                "pattern": "^0x([0-9a-fA-F]{2})*$"
                              }
                            },
                            "required": [
                              "codeHash",
                              "hashType",
                              "args"
                            ],
                            "additionalProperties": false
                          },
                          "address": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "additionalProperties": false
                      },
                      "prev_tx_hash": {
                        "type": "string",
                        "pattern": "^0x[0-9a-fA-F]{64}$"
                      }
                    },
                    "required": [
                      "manifest",
                      "payer"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
